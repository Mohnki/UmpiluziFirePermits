rules_version = '2';

// All writes go through Cloud Functions (Admin SDK bypasses these rules).
// Client-side downloads happen via short-lived signed URLs generated server-side,
// so we deny all direct client access by default.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
